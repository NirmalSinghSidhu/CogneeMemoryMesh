# MemoryMesh Docker — cloud API keys (docker-compose.cloud.yml)
#
# Copy this file before running the cloud stack:
#   cp .env.example .env
#
# Do NOT use this file for docker-compose.yml (Ollama stack) — that file
# hardcodes Ollama settings and does not need API keys.

# Database (Docker internal hostname)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/memorymesh

# ─── OpenAI (default) ───────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-your_openai_api_key_here

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── Optional: Gemini instead of OpenAI ───────────────────────────────────────
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-2.5-flash
# GEMINI_API_KEY=your_gemini_api_key_here
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini/gemini-embedding-001
# EMBEDDING_DIMENSIONS=768

# ─── Optional: Groq instead of OpenAI ─────────────────────────────────────────
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=your_groq_api_key_here
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Vector store (Cognee LanceDB)
VECTOR_DB_PROVIDER=lancedb
VECTOR_DB_PATH=/app/data/cognee/cognee.lancedb

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_MINUTES=10080

DEBUG=false
